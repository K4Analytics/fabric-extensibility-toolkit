<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata>
    <id>Org.K4Analytics</id>
    <version>1.0.0</version>
    <authors>K4 Analytics</authors>
    <owners>K4 Analytics</owners>
    <description>K4 Analytics workload for Microsoft Fabric.</description>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
  </metadata>
  <files>
    <file src="**\*.xml" target="BE" />
    <file src="**\*.json" target="FE" />
    <file src="assets\**" target="FE\assets" />
  </files>
</package>
