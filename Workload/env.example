# K4 Analytics Fabric Workload - Environment Configuration
# Copy this file to .env.dev and fill in your values

# Workload identity
WORKLOAD_NAME=Org.K4Analytics
ITEM_NAMES=K4Model

# Entra ID app registration (created by Setup.ps1)
AAD_APP_ID=<your-entra-app-client-id>
AAD_TENANT_ID=<your-tenant-id>

# Frontend dev server
DEV_SERVER_PORT=60006
